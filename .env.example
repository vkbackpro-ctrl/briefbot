# ──────────────────────────────────────
# BriefBot — Variables d'environnement
# ──────────────────────────────────────

# Anthropic API Key (commence par sk-ant-)
# Créer sur : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase
# Trouvable dans : Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxx

# Mot de passe consultant (pour accéder au dashboard)
CONSULTANT_PASSWORD=ton-mot-de-passe-secret

# URL du site (optionnel, pour les emails et liens)
NEXT_PUBLIC_APP_URL=http://localhost:3000
